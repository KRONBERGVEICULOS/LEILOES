# Desenvolvimento local padrão
# Use local-seed só para desenvolvimento de interface e conteúdo.
KRON_DATA_MODE=local-seed
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Para testar persistência real localmente:
# 1. troque KRON_DATA_MODE para postgres
# 2. configure DATABASE_URL
# 3. rode npm run migrate
DATABASE_URL=
DATABASE_SSL_MODE=disable

# Admin em dev continua opcional, mas precisa de senha forte
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-por-uma-senha-forte

# Upload local controlado para desenvolvimento.
# Em producao na Railway, use UPLOAD_STORAGE_MODE=r2 e configure Cloudflare R2.
UPLOAD_STORAGE_MODE=local
UPLOAD_PUBLIC_BASE_PATH=/media/uploads
LOT_IMAGE_MAX_MB=8

# Para testar R2 localmente, descomente e preencha:
# UPLOAD_STORAGE_MODE=r2
# CLOUDFLARE_R2_ENABLED=true
# CLOUDFLARE_R2_ACCOUNT_ID=
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# CLOUDFLARE_R2_BUCKET=
# CLOUDFLARE_R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev

# WhatsApp oficial exibido na area publica
WHATSAPP_NUMBER=5516996540954
WHATSAPP_DISPLAY=+55 16 99654-0954
WHATSAPP_URL=https://wa.me/5516996540954

# Opcionais
REDIS_URL=
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
SMOKE_BASE_URL=http://localhost:3000
