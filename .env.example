# Referência para preview/produção.
# O Next.js local carrega o arquivo real em frontend/.env.local.
# Em provedores de deploy, cadastre estas variáveis no painel do projeto.

# Banco principal do preview/produção.
# Use preferencialmente a connection string do pooler do Supabase, Neon,
# Railway Postgres ou outro Postgres gerenciado.
KRON_DATA_MODE=postgres
DATABASE_URL=postgresql://usuario:senha@host:5432/banco?sslmode=require

# Para providers gerenciados como Supabase, mantenha "require".
# Em desenvolvimento local com Postgres na máquina, use "disable".
DATABASE_SSL_MODE=require

# Cache e rate limiting opcionais com fallback seguro para Postgres/no-cache.
# Use Upstash Redis, Redis Cloud, Railway Redis ou instância própria.
REDIS_URL=redis://default:senha@host:6379

# URL pública canônica.
# Em preview na Vercel, o projeto já usa VERCEL_URL como fallback.
# Em produção com domínio final, preencha este valor.
NEXT_PUBLIC_SITE_URL=

# Acesso simples do admin do MVP.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-esta-senha

# Tokens opcionais de verificação quando existir domínio oficial.
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
