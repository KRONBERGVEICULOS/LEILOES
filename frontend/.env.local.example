# Desenvolvimento local padrão
# Use local-seed só para desenvolvimento de interface e conteúdo.
KRON_DATA_MODE=local-seed
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Para testar persistência real localmente:
# 1. troque KRON_DATA_MODE para postgres
# 2. configure DATABASE_URL
# 3. rode npm run migrate
DATABASE_URL=
DATABASE_SSL_MODE=disable

# Admin em dev continua opcional, mas precisa de senha forte
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-por-uma-senha-forte

# Opcionais
REDIS_URL=
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
SMOKE_BASE_URL=http://localhost:3000
