# Runtime local do frontend Next.js
# Copie este arquivo para frontend/.env.local e preencha os valores reais.

# Banco principal do preview/produção
# Use preferencialmente a connection string do provider de Postgres escolhido.
DATABASE_URL=postgresql://usuario:senha@host:5432/banco?sslmode=require

# Para providers gerenciados como Supabase, Railway Postgres ou Neon, use "require".
# Em desenvolvimento local com Postgres na máquina, use "disable".
DATABASE_SSL_MODE=require

# URL pública canônica.
# Em preview na Vercel, o projeto já usa VERCEL_URL como fallback.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Acesso simples do admin do MVP.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-esta-senha

# Tokens opcionais de verificação quando existir domínio oficial.
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
