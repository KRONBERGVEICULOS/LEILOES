# Produção / preview com Postgres real
# Em produção o fallback para local-seed é bloqueado.
KRON_DATA_MODE=postgres
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME
DATABASE_SSL_MODE=require

# URL pública canônica usada em metadata, canonical e sitemap.
# Railway: prefira usar uma Reference Variable apontando para o domínio público atual:
# NEXT_PUBLIC_SITE_URL=${{ RAILWAY_PUBLIC_DOMAIN }}
NEXT_PUBLIC_SITE_URL=https://kronbergveiculos.up.railway.app

# Admin mínimo endurecido
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-esta-senha-por-uma-forte

# Upload persistente em Cloudflare R2
UPLOAD_STORAGE_MODE=r2
CLOUDFLARE_R2_ENABLED=true
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
LOT_IMAGE_MAX_MB=8

# Fallback local/volume apenas para desenvolvimento controlado
UPLOAD_VOLUME_DIR=
UPLOAD_PUBLIC_BASE_PATH=/media/uploads

# WhatsApp oficial exibido na area publica
WHATSAPP_NUMBER=5516996540954
WHATSAPP_DISPLAY=+55 16 99654-0954
WHATSAPP_URL=https://wa.me/5516996540954

# Opcionais
REDIS_URL=
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
